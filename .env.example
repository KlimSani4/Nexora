# App
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-minimum-32-characters-long

# Database
DATABASE_URL=postgresql+asyncpg://nexora:nexora@localhost:5432/nexora

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-another-secret-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook/telegram
TELEGRAM_WEBHOOK_SECRET=random-secret

# CORS (JSON array or comma-separated)
CORS_ORIGINS=http://localhost:4200,http://localhost:5558,https://nexora.prdxso.dev,https://nexora.prdx.so

# Logging
LOG_LEVEL=INFO
